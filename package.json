{
  "name": "claude-virtual-office",
  "version": "1.0.0",
  "description": "Visual virtual office dashboard for Claude Code agent teams",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "claude-virtual-office": "dist/bin/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsup server/index.ts bin/cli.ts --format esm --out-dir dist --watch --onSuccess \"node dist/bin/cli.js\"",
    "dev:client": "vite --config vite.config.ts",
    "build:server": "tsup server/index.ts bin/cli.ts server/setup-hooks.ts --format esm --out-dir dist --dts",
    "build:client": "vite build --config vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/bin/cli.js",
    "setup": "node dist/bin/cli.js setup"
  },
  "keywords": [
    "claude",
    "claude-code",
    "virtual-office",
    "agent-teams",
    "dashboard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "pixi.js": "^8.16.0",
    "svelte": "^5.53.7",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
